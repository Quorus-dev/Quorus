# Production environment template
# Copy to .env.prod and fill in values

# Required secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-min-32-chars-here
BOOTSTRAP_SECRET=your-bootstrap-secret-here
RELAY_SECRET=your-relay-secret-here
POSTGRES_PASSWORD=your-strong-postgres-password
REDIS_PASSWORD=your-strong-redis-password

# Optional: Redis memory limit (default 512mb)
# REDIS_MAXMEMORY=1gb

# Optional: Relay settings
# PORT=8080
# LOG_LEVEL=WARNING
# MESSAGE_TTL_SECONDS=86400
# VISIBILITY_TIMEOUT_SECONDS=60
# IDEMPOTENCY_TTL_SECONDS=300
# RATE_LIMIT_WINDOW=60
# RATE_LIMIT_MAX=60
