# Murmur Relay — Environment Variables
# Copy to .env and fill in values, then: docker-compose up

# Required: Shared secret for legacy auth (agents without API keys)
RELAY_SECRET=change-me-to-a-long-random-string

# Required: Secret for signing JWTs (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Required: Bootstrap secret for creating the first tenant
BOOTSTRAP_SECRET=change-me-bootstrap-secret

# Optional: Server port (default 8080)
PORT=8080

# Optional: Postgres (defaults to local docker-compose postgres)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/murmur

# Optional: Redis (defaults to local docker-compose redis)
# REDIS_URL=redis://host:6379/0

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Message limits
MAX_MESSAGES=1000
MESSAGE_TTL_SECONDS=86400
RATE_LIMIT_MAX=60
MAX_ROOM_MEMBERS=50
